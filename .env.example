# Egyptian ID OCR - Environment Configuration

# App Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
APP_WORKERS=2

# Model Paths (NASO7Y - .pt files)
YOLO_CARD_MODEL=weights/detect_id_card.pt
YOLO_FIELDS_MODEL=weights/detect_odjects.pt
YOLO_NID_MODEL=weights/detect_id.pt
MODELS_CACHE_DIR=./models_cache

# YOLO Settings
YOLO_CONF_THRESHOLD=0.50
YOLO_IOU_THRESHOLD=0.45
YOLO_INPUT_SIZE=640

# OCR Settings
OCR_CPU_THREADS=4
OCR_ENABLE_MKL=true

# Image Validation
MAX_IMAGE_SIZE_MB=10
MIN_QUALITY_SCORE=0.35
TARGET_IMAGE_WIDTH=1200

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
